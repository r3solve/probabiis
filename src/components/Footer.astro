---
const currentYear = new Date().getFullYear();

const footerLinks = [
    { href: "/research", label: "Research" },
    { href: "/people", label: "People" },
    { href: "/blog", label: "Blog" },
    { href: "/contact", label: "Contact" },
];
---

<footer class="footer">
    <div class="footer-inner container">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="/" class="footer-logo">
                    <span class="logo-icon">◬</span>
                    <span>Probabilis</span>
                </a>
                <p class="footer-tagline">
                    Testing the Limits of Machine Intelligence
                </p>
            </div>

            <nav class="footer-nav">
                <h4 class="footer-heading">Navigate</h4>
                <ul class="footer-link-list">
                    {
                        footerLinks.map((link) => (
                            <li>
                                <a href={link.href}>{link.label}</a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <div class="footer-connect">
                <h4 class="footer-heading">Connect</h4>
                <ul class="footer-link-list">
                    <li><a href="mailto:contact@probabilis.ai">Email</a></li>
                    <li>
                        <a href="#" target="_blank" rel="noopener">GitHub</a>
                    </li>
                    <li>
                        <a href="#" target="_blank" rel="noopener"
                            >Twitter / X</a>
                    </li>
                    <li>
                        <a href="#" target="_blank" rel="noopener">LinkedIn</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p class="footer-copy">
                &copy; {currentYear} Probabilis. All rights reserved.
            </p>
            <p class="footer-motto">
                We are not building intelligence. We are measuring it.
            </p>
        </div>
    </div>
</footer>

<style>
    .footer {
        border-top: 1px solid var(--color-border);
        background: rgba(10, 14, 26, 0.6);
        margin-top: auto;
    }

    .footer-inner {
        padding-block: var(--space-3xl) var(--space-xl);
    }

    .footer-top {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: var(--space-3xl);
        padding-bottom: var(--space-2xl);
        border-bottom: 1px solid var(--color-border);
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        font-size: var(--text-xl);
        font-weight: 700;
        color: var(--color-text-primary);
        text-decoration: none;
        margin-bottom: var(--space-sm);
    }

    .logo-icon {
        background: var(--gradient-hero);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        font-size: var(--text-2xl);
    }

    .footer-tagline {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        max-width: 280px;
    }

    .footer-heading {
        font-size: var(--text-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text-secondary);
        margin-bottom: var(--space-md);
    }

    .footer-link-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .footer-link-list a {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        transition: color var(--transition-fast);
    }

    .footer-link-list a:hover {
        color: var(--color-accent);
    }

    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: var(--space-xl);
    }

    .footer-copy {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
    }

    .footer-motto {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        font-style: italic;
    }

    @media (max-width: 768px) {
        .footer-top {
            grid-template-columns: 1fr;
            gap: var(--space-2xl);
        }

        .footer-bottom {
            flex-direction: column;
            gap: var(--space-sm);
            text-align: center;
        }
    }
</style>
